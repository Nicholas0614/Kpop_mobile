<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Product Image -->
        <ImageView
            android:id="@+id/imgAdminProduct"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop" />

        <!-- Edit -->
        <ImageButton
            android:id="@+id/btnEditProduct"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentTop="true"
            android:layout_toStartOf="@id/btnDeleteProduct"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:src="@drawable/edit_24dp_1f1f1f_fill0_wght400_grad0_opsz24"
            android:padding="4dp"/>

        <!-- Delete -->
        <ImageButton
            android:id="@+id/btnDeleteProduct"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:background="@android:color/transparent"
            android:src="@drawable/delete_24dp_1f1f1f_fill0_wght400_grad0_opsz24"
            android:padding="4dp"/>

        <!-- Product Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgAdminProduct"
            android:layout_toStartOf="@id/btnDeleteProduct"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtAdminName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textStyle="bold"
                android:textSize="18sp"
                android:maxLines="2"/>

            <TextView
                android:id="@+id/txtAdminCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Album"
                android:textColor="#808080"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/txtAdminPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RM129"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>