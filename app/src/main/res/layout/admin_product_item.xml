<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Product Image -->
        <ImageView
            android:id="@+id/imgAdminProduct"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Delete Button -->
        <ImageButton
            android:id="@+id/btnDeleteProduct"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:padding="4dp"
            android:src="@drawable/delete_24dp_1f1f1f_fill0_wght400_grad0_opsz24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Edit Button -->
        <ImageButton
            android:id="@+id/btnEditProduct"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:padding="4dp"
            android:src="@drawable/edit_24dp_1f1f1f_fill0_wght400_grad0_opsz24"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteProduct"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Product Name -->
        <TextView
            android:id="@+id/txtAdminName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Product Name"
            android:textColor="#1F2937"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/imgAdminProduct"
            app:layout_constraintEnd_toStartOf="@id/btnEditProduct"
            app:layout_constraintTop_toTopOf="@id/imgAdminProduct" />

        <!-- Category -->
        <TextView
            android:id="@+id/txtAdminCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Album"
            android:textColor="#808080"
            app:layout_constraintStart_toStartOf="@id/txtAdminName"
            app:layout_constraintEnd_toEndOf="@id/txtAdminName"
            app:layout_constraintTop_toBottomOf="@id/txtAdminName" />

        <!-- Price -->
        <TextView
            android:id="@+id/txtAdminPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="RM129"
            android:textColor="#1F2937"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/txtAdminName"
            app:layout_constraintEnd_toEndOf="@id/txtAdminName"
            app:layout_constraintTop_toBottomOf="@id/txtAdminCategory" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>